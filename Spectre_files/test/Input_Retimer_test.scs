simulator lang=spectre
global 0 vdd!
parameters fsamp=250M J=127 M=2048 pts_per_symbol=32 tstart=400n trim0=32 \
    trim1=32 trim2=32 trim3=32 trim4=32 trim5=32 trim6=32 trim7=32 \
    tstep=1/(pts_per_symbol*fsamp) tstop=tstart + (M+10)/fsamp
include "/homes/user/stud/fall25/yw4576/pdk/TSMC018_teaching.scs" section=tt

subckt Test_Trim_Input_DC_Array T0\<0\> T0\<1\> T0\<2\> T0\<3\> T0\<4\> \
        T0\<5\> T1\<0\> T1\<1\> T1\<2\> T1\<3\> T1\<4\> T1\<5\> T2\<0\> \
        T2\<1\> T2\<2\> T2\<3\> T2\<4\> T2\<5\> T3\<0\> T3\<1\> T3\<2\> \
        T3\<3\> T3\<4\> T3\<5\> T4\<0\> T4\<1\> T4\<2\> T4\<3\> T4\<4\> \
        T4\<5\> T5\<0\> T5\<1\> T5\<2\> T5\<3\> T5\<4\> T5\<5\> T6\<0\> \
        T6\<1\> T6\<2\> T6\<3\> T6\<4\> T6\<5\> T7\<0\> T7\<1\> T7\<2\> \
        T7\<3\> T7\<4\> T7\<5\>
    V11 (T6\<3\> 0) vsource dc=1.8*(floor(trim6/8)-2*floor(trim6/16)) \
        type=dc
    V10 (T7\<3\> 0) vsource dc=1.8*(floor(trim7/8)-2*floor(trim7/16)) \
        type=dc
    V9 (T6\<4\> 0) vsource dc=1.8*(floor(trim6/16)-2*floor(trim6/32)) \
        type=dc
    V8 (T7\<4\> 0) vsource dc=1.8*(floor(trim7/16)-2*floor(trim7/32)) \
        type=dc
    V7 (T7\<5\> 0) vsource dc=1.8*(floor(trim7/32)-2*floor(trim7/64)) \
        type=dc
    V6 (T6\<5\> 0) vsource dc=1.8*(floor(trim6/32)-2*floor(trim6/64)) \
        type=dc
    V5 (T7\<2\> 0) vsource dc=1.8*(floor(trim7/4)-2*floor(trim7/8)) \
        type=dc
    V4 (T7\<1\> 0) vsource dc=1.8*(floor(trim7/2)-2*floor(trim7/4)) \
        type=dc
